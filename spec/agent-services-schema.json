{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rail402.app/spec/agent-services-schema.json",
  "title": "Agent Services Discovery Document",
  "description": "Schema for /.well-known/agent-services.json — a machine-readable catalog of paid APIs an AI agent can discover and call via x402.",
  "type": "object",
  "required": ["version", "provider", "services"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "description": "Spec version this document conforms to.",
      "pattern": "^\\d+\\.\\d+$",
      "examples": ["1.0"]
    },
    "provider": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "wallet": {
          "type": "string",
          "description": "Default payout wallet (EVM address).",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        },
        "contact": { "type": "string" }
      }
    },
    "services": {
      "type": "array",
      "minItems": 0,
      "items": { "$ref": "#/$defs/service" }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "required": ["id", "name", "endpoint", "method", "price", "inputSchema", "outputSchema"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable, URL-safe identifier unique within this provider.",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "endpoint": {
          "type": "string",
          "format": "uri",
          "description": "Absolute HTTPS URL the agent calls."
        },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
        },
        "price": { "$ref": "#/$defs/price" },
        "inputSchema": {
          "type": "object",
          "description": "JSON Schema for the request body the caller must send."
        },
        "outputSchema": {
          "type": "object",
          "description": "JSON Schema for the response body the caller can expect."
        },
        "exampleRequest": {},
        "exampleResponse": {},
        "documentation": { "type": "string" },
        "auth": {
          "type": "string",
          "description": "Authentication scheme. x402 means pay-per-call via the price field.",
          "enum": ["x402", "none"],
          "default": "x402"
        }
      }
    },
    "price": {
      "type": "object",
      "required": ["amount", "currency", "network"],
      "additionalProperties": false,
      "properties": {
        "amount": {
          "type": "string",
          "description": "Human-readable price, e.g. \"0.05\".",
          "pattern": "^\\d+(\\.\\d+)?$"
        },
        "currency": { "type": "string", "enum": ["USDC"] },
        "network": { "type": "string", "enum": ["base", "base-sepolia"] },
        "payTo": {
          "type": "string",
          "description": "Per-service payout wallet; overrides provider.wallet.",
          "pattern": "^0x[a-fA-F0-9]{40}$"
        }
      }
    }
  }
}
