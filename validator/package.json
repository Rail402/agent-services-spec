{
  "name": "@rail402/validate-spec",
  "version": "1.0.0",
  "description": "Validate an agent-services.json discovery document against the Rail402 Agent Services spec.",
  "license": "MIT",
  "type": "module",
  "bin": { "validate-spec": "./dist/cli.js" },
  "main": "./dist/validate.js",
  "types": "./dist/validate.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/cli.ts src/validate.ts --format esm --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["rail402", "x402", "agent-services", "json-schema", "validator", "cli"],
  "repository": { "type": "git", "url": "git+https://github.com/rail402/agent-services-spec.git" },
  "engines": { "node": ">=18" },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
